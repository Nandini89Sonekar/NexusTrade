rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid (string), email (string), balance (number), createdAt (number)
    //
    // Collection: trades
    // Fields: userId (string), symbol (string), type (string), amount (number), price (number), timestamp (number)
    //
    // Collection: portfolios
    // Fields: userId (string), symbol (string), amount (number), averagePrice (number)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'balance', 'createdAt']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string &&
             data.balance is number &&
             data.createdAt is number;
    }

    function isValidTrade(data) {
      return data.keys().hasAll(['userId', 'symbol', 'type', 'amount', 'price', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.symbol is string &&
             data.type in ['BUY', 'SELL'] &&
             data.amount is number && data.amount > 0 &&
             data.price is number && data.price > 0 &&
             data.timestamp is number;
    }

    function isValidPortfolio(data) {
      return data.keys().hasAll(['userId', 'symbol', 'amount', 'averagePrice']) &&
             data.userId == request.auth.uid &&
             data.symbol is string &&
             data.amount is number &&
             data.averagePrice is number;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid &&
                    request.resource.data.createdAt == resource.data.createdAt;
    }

    match /trades/{tradeId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidTrade(request.resource.data);
    }

    match /portfolios/{portfolioId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidPortfolio(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidPortfolio(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
